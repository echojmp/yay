{
	"schemaVersion": 1,
	"id": "yay",
	"version": "${version}",
	"name": "yay",
	"description": "A minecraft mod with things I made to learn / for fun, I don't recommend using this in a modpack cause of this",
	"authors": [
		"echojmp"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "MIT",
